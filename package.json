{
  "name": "regalarte-store",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "dev:functions": "wrangler pages dev --proxy 4321 --env-file=.env --compatibility-date=2025-04-01",
    "astro": "astro",
    "typecheck": "astro check",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "admin:grant": "tsx --env-file=.env scripts/set-admin.ts",
    "firebase": "firebase",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "migrate:sanity": "tsx --env-file=.env scripts/migrate-sanity-to-firebase.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/tailwind": "^6.0.2",
    "@sanity/astro": "^3.4.0",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.30.0",
    "aos": "^2.3.4",
    "astro": "^7.0.7",
    "cloudinary": "^2.7.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^5.30.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/aos": "^3.0.8",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "firebase-tools": "^15.23.0",
    "tsx": "^4.22.4",
    "wrangler": "^4.110.0"
  }
}
