# Variables públicas del panel (es normal que terminen dentro del JavaScript del navegador)
PUBLIC_FIREBASE_API_KEY=""
PUBLIC_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
PUBLIC_FIREBASE_PROJECT_ID="tu-proyecto"
PUBLIC_FIREBASE_STORAGE_BUCKET="tu-proyecto.firebasestorage.app"
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
PUBLIC_FIREBASE_APP_ID=""

# Firebase en el build estático y en scripts locales (privadas)
FIREBASE_PROJECT_ID="tu-proyecto"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternativa a las tres variables anteriores: JSON completo de la cuenta de servicio.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"..."}'

# Pages Functions (privadas en Cloudflare salvo CLOUDINARY_FOLDER)
FIREBASE_WEB_API_KEY=""
CLOUDFLARE_DEPLOY_HOOK_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="regalarte/catalog"

# Solo para ejecutar una migración desde la versión Sanity
SANITY_PROJECT_ID=""
SANITY_DATASET="production"
SANITY_API_VERSION="2026-03-01"
SANITY_READ_TOKEN=""
